#!/usr/bin/env bash

set -eo pipefail

count=0
error_log="$OUTFILES/decompilation-errors.txt"

# Function to log errors
log_error() {
    local message="$1"
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') - $message" | tee -a "$error_log" >&2
}

# Function to log info messages
log_info() {
    local message="$1"
    echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') - $message" | tee -a "$error_log"
}

function decompile_jars {
    local infiles
    local libfiles
    local classpath
    local decompiler
    local outdir

    # Use default input and library directories if none are specified
    infiles="${1:-$INFILES}"
    libfiles="${2:-$LIBFILES}"

    # Create classpath from libfiles directory
    if [ "$(ls -A $libfiles/*.jar 2>/dev/null)" ]; then
        classpath=$(find "$libfiles" -name "*.jar" | tr '\n' ':')
    else
        classpath=""
    fi

    if [ "$(ls -A $infiles/*.jar 2>/dev/null)" ]; then
        for jarfile in $infiles/*.jar; do
            jarcount=0

            for decompiler in 'cfr' 'vineflower' 'procyon'; do
                outdir="$OUTFILES/$(basename $jarfile)-$decompiler"
                if [[ -e "$outdir" ]]; then
                    log_info "Directory '$outdir' already exists. Skipping..."
                else
                    ((jarcount+=1))
                    log_info "Decompiling $(basename $jarfile) with $decompiler"
                    case $decompiler in
                        'cfr')
                            mkdir -p "$outdir"
                            # CFR decompilation, pass classpath if available
                            if [ -n "$classpath" ]; then
                                java "-Xmx$JAVA_XMX" -jar /opt/cfr.jar "$jarfile" --outputdir "$outdir" --extraclasspath "$classpath" 2>> "$error_log" || log_error "Failed to decompile $jarfile with CFR"
                            else
                                java "-Xmx$JAVA_XMX" -jar /opt/cfr.jar "$jarfile" --outputdir "$outdir" 2>> "$error_log" || log_error "Failed to decompile $jarfile with CFR"
                            fi
                            ;;
                        'vineflower')
                            mkdir -p "$outdir"
                            local vf_lib_args=""
                            if [ -n "$classpath" ]; then
                                IFS=':' read -ra LIBS <<< "$classpath"
                                for lib in "${LIBS[@]}"; do
                                    if [ -n "$lib" ] && [ -f "$lib" ]; then
                                        vf_lib_args="$vf_lib_args -e=$lib"
                                    fi
                                done
                            fi
                            java "-Xmx$JAVA_XMX" -jar /opt/vineflower.jar --folder $vf_lib_args "$jarfile" "$outdir" 2>> "$error_log" || log_error "Failed to decompile $jarfile with Vineflower"
                            ;;
                        'procyon')
                            mkdir -p "$outdir"
                            # Procyon decompilation, classpath might be needed for full decompilation
                            if [ -n "$classpath" ]; then
                                procyon -jar "$jarfile" -cp "$classpath" -o "$outdir" 2>> "$error_log" || log_error "Failed to decompile $jarfile with Procyon"
                            else
                                procyon -jar "$jarfile" -o "$outdir" 2>> "$error_log" || log_error "Failed to decompile $jarfile with Procyon"
                            fi
                            ;;
                    esac
                fi
            done

            if [[ "$jarcount" -gt 0 ]]; then
                ((count+=1))
            fi
        done
    else
        log_info "No JAR files found in $infiles"
    fi
}

log_info "Starting decompilation process"
decompile_jars "$INFILES" "$LIBFILES"

if [[ "$count" -eq 0 ]]; then
    log_error "No files were processed."
    exit 1
else
    log_info "Processed $count JAR files"
    log_info "Formatting decompiled Java files"
    find "$OUTFILES" -type f -iname '*.java' -print0 | xargs -0 --max-procs=8 astyle --suffix=none --style=java --indent=tab 2>> "$error_log" || log_error "Failed to format some Java files"
fi

log_info "Decompilation process completed. Check $error_log for any errors."
